@article{ WOS:001058345000001,
Author = {Krishna, P. U. Neenu and Muraleedharan, K.},
Title = {alpha-Terthiophene and its functionalized derivatives from roots of
   Echinops grijisii to produce potential organic semiconductor
   materials: A theoretical study},
Journal = {MATERIALS TODAY COMMUNICATIONS},
Year = {2023},
Volume = {36},
Month = {AUG},
Abstract = {DFT calculations were done to explore the optical and electronic
   properties of \& alpha;-Terthiophene (\& alpha;-TTP) and its
   functionalized derivates from Echinops grijisii, as potential organic
   semiconductors (OSCs). The properties estimated by the B3LYP-GD3/6-31
   +G(d,p) technique include reorganization energy(\& lambda;e and \&
   lambda;h), ionization potential (IP), electron affinity(EA), and
   bandgap(Eg). The TD-DFT/CAM-B3LYP approach was also used to explore the
   \& lambda;max at the first excited states in vacuum. \& alpha;-TTP is
   considered an n-type material, its functionalization resulted in a
   decrease in Eg and LUMO energy levels, indicating their potential use as
   n-type OSCs. All the molecules exhibit lower \& lambda;e, which is in
   line with the IP and EA values. Compared to others, 5-Acetyl-\&
   alpha;-TTP has stronger EA, lowest Eg, lower \& lambda;e and LUMO
   confirming its better performance as n-type OSCs. The visualization of
   TDM maps, explains local excitation in all molecules. Moreover, the ESP
   map identifies variance in electron density in the skeletal backbone of
   studied molecules.},
Type = {Article},
Language = {English},
DOI = {10.1016/j.mtcomm.2023.106453},
