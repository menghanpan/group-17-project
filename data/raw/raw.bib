@article{ WOS:001521260300002,
Author = {Chen, Xu and Iwahashi, Takashi and Isobe, Momoka and Kanai, Kaname and
   Michinobu, Tsuyoshi},
Title = {Synthesis of pyridine-based push-pull chromophores via {[}2+2]
   cycloaddition-retroelectrocyclization and their p-doping performance in
   poly(3-hexylthiophene-2,5-diyl)},
Journal = {DYES AND PIGMENTS},
Year = {2025},
Volume = {242},
Month = {NOV},
Abstract = {P-type doping is a widely adopted strategy to enhance the performance of
   organic semiconductors (OSCs), underscoring the importance and urgency
   of developing novel p-dopants. In this study, a series of pyridine-based
   cyano-acceptors were newly synthesized via a click-type {[}2 + 2]
   cycloaddition-retroelectrocyclization (CA-RE) reaction of
   aminopyridine-substituted alkynes with tetracyanoethylene (TCNE) and
   7,7,8,8-tetracyanoquinodimethane (TCNQ) under mild conditions. Their
   thermal stability, optical and electrochemical properties were
   characterized using thermogravimetric analysis (TGA), UV-vis
   spectroscopy, and cyclic voltammetry (CV). Furthermore, the p-doping
   performance of these cyano-rich acceptors, both before and after
   coordination with the Lewis acid tris(pentafluorophenyl)borane (BCF),
   was evaluated by photoelectron yield spectroscopy (PYS) and ultraviolet
   photoelectron spectroscopy (UPS).},
