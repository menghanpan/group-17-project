@article{ WOS:001463395200001,
Author = {Shi, Lei and Troisi, Alessandro},
Title = {High-Throughput Screening of Molecule/Polymer Photocatalysts for the
   Hydrogen Evolution Reaction},
Journal = {ACS CATALYSIS},
Year = {2025},
Volume = {15},
Number = {9},
Pages = {6690-6701},
Month = {APR 10},
Abstract = {Although there has been progress in designing organic photocatalysts,
   identifying and designing structurally distinct polymeric or molecular
   photocatalysts with high performance is still challenging. Using the
   properties of a set of well-known polymer photocatalysts, we performed a
   virtual screening of a large data set of around 50 000 organic
   semiconductors. In the initial stage, we looked for candidates with
   electronic properties similar to those of the best-performing
   photocatalysts. Next, we screened the data set using reactivity
   descriptors based on mechanisms derived from quantum chemical
   calculations for selected cases. We identified 33 candidates with high
   potential as photocatalysts for the hydrogen evolution reaction.},
Type = {Article},
Language = {English},
DOI = {10.1021/acscatal.5c01785},
