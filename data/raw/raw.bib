@article{ WOS:001494001600001,
Author = {Chen, Bihong and Pan, Yuehua and Deng, Yuxiang and Yang, Libo and Wang,
   Nannan and Wei, Yuezhou and He, Chunlin and Wang, Xinpeng},
Title = {In situ preparation of a novel organic-inorganic COFs@Bi/BiOBr composite
   for efficient photocatalytic uranium extraction},
Journal = {SEPARATION AND PURIFICATION TECHNOLOGY},
Year = {2025},
Volume = {370},
Month = {OCT 18},
Abstract = {The photocatalytic reduction method is an effective strategy for the
   removal of U(VI) from radioactive nuclear wastewater. In this study,
   novel organic-inorganic composite materials COFs@Bi/BiOBr with different
   compounding amounts were synthesized. The inorganic semiconductor
   Bi/BiOBr, with in-situ loaded metallic bismuth and oxygen vacancies,
   served as the substrate for the in-situ growth of the triazine-based
   covalent organic framework TpTt as the organic semiconductor to form
   composite materials (Tp = 1,3,5-triformylphloroglicinol, Tt = melamine).
   The incorporation of Bi and oxygen vacancies significantly enhanced the
   light absorption capacity of BiOBr and narrowed its band gap. The
   substantial specific surface area of TpTt provided ample active sites
   for photocatalytic reactions. Additionally, the construction of a
   heterojunction facilitated the separation and transfer of charge
   carriers within the composite material, thereby endowing the material
   with excellent photocatalytic efficiency. Upon exposure to visible light
   irradiation, TpTt@Bi/BiOBr generated reactive oxygen species and
   photoelectrons, which effectively facilitated the chemical reduction of
   U(VI) adsorbed within TpTt, achieving a U(VI) extraction efficiency of
   97.1 \% within 180 min. Comprehensive structural characterization
   coupled with rigorous theoretical calculation analysis elucidate the
   underlying mechanism governing the photoreduction of U(VI). This study
   introduced a novel design for organic-inorganic COFs heterojunctions and
   demonstrated an effective visible-light-driven method for extracting
   radioactive U(VI).},
Type = {Article},
Language = {English},
DOI = {10.1016/j.seppur.2025.133120},
