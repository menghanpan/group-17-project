@article{ WOS:000690440900033,
Author = {Wang, Jia and Xie, Ya-Hong and Amano, Hiroshi},
Title = {High-Gain Gated Lateral Power Bipolar Junction Transistor},
Journal = {IEEE ELECTRON DEVICE LETTERS},
Year = {2021},
Volume = {42},
Number = {9},
Pages = {1370-1373},
Month = {SEP},
Abstract = {We demonstrated a prototype Gated Lateral power bipolar junction
   transistor (GLP-BJT) on wide bandgap semiconductor. The device combined
   the intrinsic advantages of high current gain of a Gated Lateral-BJT and
   good current handling and voltage blocking capabilities of GaN material.
   As a result, the common-emitter current gain remained over 300 at a high
   collector current density of 2 kA/cm(2) despite a wide p- base region of
   2 mu m. The open base breakdown voltageBVCEO was over 300 V
   corresponding to a high critical field of 2.5MV/cm. These figures
   ofmerit show great promise of GaN-based GLP-BJT in power applications
   and also shed light on the development of stateof- the-art bipolar
   transistors based on other wide bandgap semiconductors.},
