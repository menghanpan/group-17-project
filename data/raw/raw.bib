@article{ WOS:001199854600012,
Author = {Hubenko, Kateryna and Kusber, Anncharlott and Naumann, Marco and
   Buechner, Bernd and Knupfer, Martin},
Title = {Evolution of the pentacene exciton band width in pentacene-tetracene
   blends},
Journal = {JOURNAL OF CHEMICAL PHYSICS},
Year = {2024},
Volume = {160},
Number = {14},
Month = {APR 14},
Abstract = {Pentacene is one of the most investigated organic semiconductors. It is
   well known that the motion of excitons in pentacene and other organic
   semiconductors is determined by inter-molecular exciton coupling based
   on charge-transfer processes. In the present study, we demonstrate the
   impact of the admixture of tetracene, which has a larger band gap and
   interrupts the pentacene-pentacene interaction, on the exciton behavior
   in pentacene. Using a combination of optical absorption and electron
   energy-loss spectroscopy, we show that both the Davydov splitting and
   the exciton band width in pentacene strongly decrease with increasing
   tetracene concentration, while the decrease of the exciton band width is
   substantially larger.},
