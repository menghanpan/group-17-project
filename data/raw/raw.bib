@article{ WOS:001217432400001,
Author = {Sideltsev, M. E. and Zhivchikova, A. N. and Kuznetsov, I. E. and
   Sagdullina, D. K. and Tepliakova, M. M. and Piryazev, A. A. and Anokhin,
   D. V. and Maksimovich, M. S. and Nikitenko, N. G. and Ivanov, D. A. and
   Akkuratov, A. V.},
Title = {Alkylsilyl-substituted benzodithiophene-based small molecules as
   promising hole-transport materials for perovskite solar cells},
Journal = {SUSTAINABLE ENERGY \& FUELS},
Year = {2024},
Volume = {8},
Number = {11},
Pages = {2437-2445},
Month = {MAY 28},
Abstract = {Organic semiconductor small molecules have gained significant attention
   as interfacial hole-transport materials (HTMs) for application in
   perovskite solar cells (PSCs). Herein, we report the investigation of
   three donor-acceptor small molecules consisting of benzodithiophene,
   benzothiadiazole, and thiophene moieties as HTMs. The morphology, charge
   mobility, and charge extraction ability of the developed molecules are
   shown to strongly depend on the shape and number of alkylsilyl side
   groups. The optimized PSCs with HTM TB-Si3-3 comprising four peripheral
   (i-Pr)3Si-groups delivered the best power conversion efficiency of
   16.8\%. The results obtained suggest the great potential of
   alkylsilyl-substituted small molecules as dopant-free HTMs for
   perovskite photovoltaic applications.
   The PSCs with newly designed TB-Si3-3 delivered high power conversion
   efficiency of 16.8\% and good operational stability featuring the great
   potential of alkylsilyl-substituted small molecules as dopant-free HTMs
   for perovskite photovoltaic applications.},
