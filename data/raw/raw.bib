@article{ WOS:001492263000002,
Author = {Wang, Yuchen and Pan, Qianqian and Cai, Songlin and Liang, Liwei and
   Chen, Liangsheng and Zhang, Ruirui and Liu, Liu and Yin, Yanzhen and
   Yang, Tao and Zhu, Hongxiang and Liu, Tao},
Title = {The novel biochar-based organic semiconductor toward broadband and
   direct radicals transfer enhanced photocatalytic degradations},
Journal = {JOURNAL OF ENVIRONMENTAL MANAGEMENT},
Year = {2025},
Volume = {386},
Month = {JUN},
Abstract = {Organic semiconductor materials manifest themselves as fascinating light
   absorbers and high-speed carrier transport for applications in
   photocatalytic degradation and solar energy harvesting. The essential
   challenges lie in harvesting the complex synthesis processes and poor
   recyclability. To this end, a synergistic deposition strategy utilizing
   organic semiconductor materials extracted from discarded solar cells and
   natural adsorbent biochar has been proposed to mitigate these two
   challenges. Specifically, by utilizing impregnation method, we
   successfully constructed the D-A heterojunction organic semiconductor
   photocatalytic materials on the surface of biochar. Organic
   photocatalytic materials, PCE10:PC71BM, has the wide absorption spectrum
   within the range of 400-800 nm, which allows for the massive generation
   of electrons and holes for photoreactions under illumination. Hence,
   such catalyzer can completely remove Malachite Green at a concentration
   of 80 mg/L within 15 min under weaken light condition (30 mW/cm2) due to
   the utilization of light energy by the organic semiconductor material to
   generate a large number of radicals with strong redox properties (Such
   as h(+)/center dot OH/center dot O-2(-)/O-1(2)), which ultimately
   degrade the pollutants into non-toxic and harmless small molecules.},
