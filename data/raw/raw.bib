@article{ WOS:000842795900001,
Author = {Yang, Yongfan and de Moraes, Lygia Silva and Ruzie, Christian and
   Schweicher, Guillaume and Geerts, Yves Henri and Kennedy, Alan R. and
   Zhou, Hengyu and Whittaker, St John and Lee, Stephanie S. and Kahr, Bart
   and Shtukenberg, Alexander G.},
Title = {Charge Transport in Twisted Organic Semiconductor Crystals of Modulated
   Pitch},
Journal = {ADVANCED MATERIALS},
Year = {2022},
Volume = {34},
Number = {38},
Month = {SEP},
Abstract = {Many molecular crystals (approximately one third) grow as twisted,
   helicoidal ribbons from the melt, and this preponderance is even higher
   in restricted classes of materials, for instance, charge-transfer
   complexes. Previously, twisted crystallites of such complexes present an
   increase in carrier mobilities. Here, the effect of twisting on charge
   mobility is better analyzed for a monocomponent organic semiconductor,
   2,5-bis(3-dodecyl-2-thienyl)-thiazolo{[}5,4-d]thiazole (BDT), that forms
   twisted crystals with varied helicoidal pitches and makes possible a
   correlation of twist strength with carrier mobility. Films are analyzed
   by X-ray scattering and Mueller matrix polarimetry to characterize the
   microscale organization of the polycrystalline ensembles. Carrier
   mobilities of organic field-effect transistors are five times higher
   when the crystals are grown with the smallest pitches (most twisted),
   compared to those with the largest pitches, along the fiber elongation
   direction. A tenfold increase is observed along the perpendicular
   direction. Simulation of electrical potential based on scanning electron
   microscopy images and density functional theory suggests that the
   twisting-enhanced mobility is mainly controlled by the fiber
   organization in the film. A greater number of tightly packed twisted
   fibers separated by numerous smaller gaps permit better charge transport
   over the film surface compared to fewer big crystallites separated by
   larger gaps.},
Type = {Article},
Language = {English},
DOI = {10.1002/adma.202203842},
EarlyAccessDate = {AUG 2022},
Article-Number = {2203842},
