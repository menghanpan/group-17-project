@article{ WOS:001177746400001,
Author = {Yang, Xuwen and Ye, Gang and Tran, Karolina and Liu, Yuru and Cao,
   Jiamin and Dong, Jingjin and Portale, Giuseppe and Liu, Jian and Zhang,
   Ping and Loi, Maria Antonietta and Chiechi, Ryan C. and Koster, L. Jan
   Anton},
