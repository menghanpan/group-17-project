@article{ WOS:001456014800001,
Author = {Lee, Jehoon and Choi, Jaeyeong and Son, Jaewon and Kang, Jungwon},
Title = {High-Performance Resistive Random-Access Memory Based on the 2D Cadmium
   Selenide Nanoplate-Organic Semiconductor Hybrid Structure},
Journal = {ACS APPLIED ELECTRONIC MATERIALS},
Year = {2025},
Volume = {7},
Number = {8},
Pages = {3219-3229},
Month = {MAR 31},
Abstract = {Resistive random-access memory (RRAM) has emerged as a promising
   alternative to conventional memory components, offering nonvolatility,
   high density, low power consumption, and fast read/write speeds. This
   study investigates the integration of 2D cadmium selenide nanoplates
   (CdSe NPLs) into an organic semiconductor to enhance the RRAM
   performance. Utilizing poly(vinylcarbazole) (PVK) as the organic
   semiconductor, we systematically evaluate the impact of CdSe NPLs on
   memory properties. Our findings demonstrate that CdSe NPL integration
   enhances both charge entrapment and release, resulting in nonvolatile
   memory attributes and rewritability. The synergistic interplay between
   CdSe NPLs and the energy barrier of PVK defines distinct memory
   properties. Fabricated CdSe-PVK RRAM devices exhibit impressive
   performance characteristics, including a current ON/OFF ratio exceeding
   105, a retention time exceeding 105 seconds, and an operational voltage
   below +3 V. These results surpass those reported in similar studies,
   highlighting the efficacy of integrating CdSe NPLs into RRAM materials.
   Overall, this study provides insights into the enhanced performance of
   RRAM through nanostructure integration, paving the way for further
   research in this promising area.},
Type = {Article},
Language = {English},
DOI = {10.1021/acsaelm.4c02122},
EarlyAccessDate = {MAR 2025},
Keywords = {CdSe nanoplatelets; RRAM; PVK; 2D-oraniccomposite; hybrid memory device},
