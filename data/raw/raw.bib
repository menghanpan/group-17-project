@article{ WOS:000820562300002,
Author = {Zhang, Yahong and Jiang, Dandan and Zhang, Hanyu and Cheng, Jinghui and
   Guan, Huijuan and Cai, Kun and Yang, Qi and Zhang, Yange},
Title = {Anisotropic Charge Transfer Mobility Properties of Systems with Large
   Conjugation Core and Peripheral Phenyl Rings},
Journal = {JOURNAL OF CLUSTER SCIENCE},
Year = {2023},
Volume = {34},
Number = {3},
Pages = {1291-1298},
Month = {MAY},
Abstract = {The role of crystal structures and electronic properties has been widely
   investigated for carrier transport in organic semiconductors. The
   first-principles method was applied to analyse the effect of effective
   electronic couplings and reorganization energy on the carrier mobility
   for the combination of large conjugation core and peripheral phenyl
   rings. It is found that for compound 1 and compound 2, the
   reorganization energies of hole transfer (lambda(h)) are all smaller
   than those of electron transfer (lambda(e)), furthermore, the
   reorganization energy of hole transfer for compound 1 is much lower than
   compound 2. The monomer of compound 1 has the lower ionization potential
   which will contribute to the reception of holes. The change of molecular
   stacking modes will also influence the charge transport performance,
   which can be drawn from the theoretical calculation of the mobility of
   single crystal structure. The electronic couplings of compound 1 are
   basically greater than that of compound 2. For compound 1 crystal, the
   relatively superior intermolecular electronic coupling and weak
   reorganization energy of hole transport would make it play a part as an
   organic semiconductor materials of p-type. The theoretical prediction
   should be a promising strategy to provide clearer design guidelines for
   further promotion in carrier mobility.},
Type = {Article},
Language = {English},
DOI = {10.1007/s10876-022-02307-5},
EarlyAccessDate = {JUL 2022},
Keywords = {Organic semiconductor; First-principles; Electronic coupling;
   Reorganization energy},
Keywords-Plus = {ORGANIC SEMICONDUCTORS; ELECTRON-TRANSFER; HOLE MOBILITIES; TRANSPORT;
   SUBSTITUENT; CONSTRUCTION; DERIVATIVES; PARAMETERS; CHEMISTRY; OLIGOMERS},
