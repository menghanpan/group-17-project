@article{ WOS:000829843400010,
Author = {Fukasawa, E. and Miyata, H. and Miyata, E. and Katsumata, M. and Sato,
   H. and Ono, H. and Watanabe, M. and Saito, E. and Seino, Y. and Umeyama,
   A. and Sato, M. and Tamura, M. and Suzuki, T.},
Title = {A novel radiation detector based on Gd2O3 doped
   organic semiconductor for the detection of γ and β-particles},
Journal = {NUCLEAR INSTRUMENTS \& METHODS IN PHYSICS RESEARCH SECTION
   A-ACCELERATORS SPECTROMETERS DETECTORS AND ASSOCIATED EQUIPMENT},
Year = {2022},
Volume = {1034},
Month = {JUL 1},
Abstract = {A radiation detector that consists of a conducing polymer derived from
   an organic semiconductor material was developed. The motivation behind
   this study was to reduce the detector costs and to find a suitable
   alternative to large inorganic semiconductor detectors, which are
   difficult to fabricate. Herein, we report an unprecedented effort made
   to detect gamma-particles using organic semiconductor, polyaniline,
   sensors. In addition, the novel organic semiconductor sensors also
   exhibited improved detection of beta-particles compared with other
   conventional sensors. The material density of the sensor was increased
   to enhance the detection sensitivity. We focused on materials with high
   electron density and improved the gamma and beta-particle sensitivity by
   doping the material with gadolinium oxide (Gd2O3). When the Gd2O3 doped
   material was used in a hybrid organicinorganic radiation detector, the
   detection sensitivity of the detector improved for gamma-particles
   ejected from a Co-60 source. Further, an attempt was made to fabricate
   sensors with improved beta-particle sensitivity by adopting several
   approaches, including doping Gd2O3, using polyaniline with fine-tuned
   oxidation states, and modifying electrode designs. The target detector
   efficiency of 20\% was achieved in the environment of a university
   laboratory, which is necessary to commercialize the organic radiation
   sensor.},
Type = {Article},
Language = {English},
DOI = {10.1016/j.nima.2022.166797},
EarlyAccessDate = {MAY 2022},
Article-Number = {166797},
