@inproceedings{ WOS:001515800500002,
Author = {Janotti, Anderson and Chatratin, Intuon and Evangelista, Igor},
Editor = {Rogers, DJ and Teherani, FH},
Title = {Doping and defects in wide-band-gap perovskite semiconductors},
Booktitle = {OXIDE-BASED MATERIALS AND DEVICES XVI},
Series = {Proceedings of SPIE},
Year = {2025},
Volume = {13367},
Note = {2025 Conference on Oxide Based Materials and Devices, San Francisco, CA,
   JAN 26-29, 2025},
Abstract = {Perovskite semiconductors form a large family of materials with great
   potential in high-performance and energy-efficient devices across
   diverse applications, such as power electronics, UV optoelectronics,
   sensors that operate under extreme environments, and catalysis.
   Controlling the incorporation of impurities (doping) and native defects
   is key to tuning their electronic and optical properties, thus enabling
   functionalization. Despite significant advances in materials growth,
   processing, characterization, and computational modeling in the last
   decades, fundamental questions on the electrical and optical activities
   of impurities and defects, their nature as shallow or deep donors, as
   sources of conductivity or compensation centers, or causes of deep-level
   luminescence are still being debated. Here, we discuss some results of
   hybrid density functional theory calculations on the role of doping and
   defects in wide-band-gap perovskite semiconductors, using KTaO3, SrTiO3,
   and CaSnO3 as examples. We discuss how hydrogen impurities lead to
   unusual persistent photoconductivity in KTaO3 and SrTiO3 that occur at
   room temperature and last for months, emphasizing the role of
   interstitial and substitutional hydrogen, oxygen vacancies, and metal
   vacancies in this intriguing phenomenon. We also discuss the impact of
   extreme doping concentrations on the structural and electrical
   properties of CaSnO3, a material with a band gap of over 4 eV, where
   unexpected measurable effects on the lattice parameters due to high
   doping levels have been observed. All these results are discussed
   considering recent experimental observations.},
Type = {Proceedings Paper},
Language = {English},
