Title = {Ferromagnetic Double Perovskite Semiconductors with Tunable Properties},
Journal = {ADVANCED SCIENCE},
Year = {2022},
Volume = {9},
Number = {8},
Month = {MAR},
Abstract = {The authors successfully dope the magnetically silent double perovskite
   semiconductor Sr2GaSbO6 to induce ferromagnetism and tune its bandgap,
   with Ga3+ partially substituted by the magnetic trivalent cation Mn3+,
   in a rigid cation ordering with Sb5+. The new ferromagnetic
   semiconducting Sr2Ga1-xMnxSbO6 double perovskite, which crystallizes in
   tetragonal symmetry (space group I4/m) and has tunable ferromagnetic
   ordering temperature and bandgap, suggests that magnetic ion doping of
   double perovskites is a productive avenue toward obtaining materials for
   application in next-generation oxide-based spintronic devices.},
