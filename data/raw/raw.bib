@article{ WOS:001541932200001,
Author = {Hassan, Istiqlal and Lee, Hyo Chan and Cho, Kilwon},
Title = {Thickness-dependent charge transfer and morphological evolution of
   planar organic semiconductors on graphene},
Journal = {CHEMICAL ENGINEERING JOURNAL},
Year = {2025},
Volume = {520},
Month = {SEP 15},
Abstract = {The performance of organic optoelectronic devices is significantly
   influenced by the morphology of organic semiconductor thin films used in
   the device. Two-dimensional materials, such as graphene, provide an
   excellent platform for controlling the morphology of OSC thin films. In
   this study, we examine the impact of in-situ electrical doping
   consequently charge transfer from underlaying graphene to planar small
   molecule organic semiconductor on the morphology of OSC thin films.
   Graphene substrates were electrically doped during the deposition of
   PTCDA, and the resulting morphological changes in the films were
   characterized. Charge transfer significantly influenced the morphology
   of PTCDA films. Specifically, at a nominal thickness of 9 nm, the
   average domain size of the organic semiconductor thin film without
   charge transfer was approximately 239 nm, which decreased to 92.4 nm in
   the presence of charge transfer. Notably, these effects were observed in
   films with thicknesses below 30 nm. In contrast, thicker films showed
   negligible charge transfer effects, suggesting a thickness-dependent
   charge transfer mechanism. Moreover, exciton diffusion length for the
   films without charge transfer is over 3 times higher than with charge
   transfer films. These findings offer key insights for optimizing
   graphene-based interfaces in electronic and optoelectronic applications
   of organic semiconductors.},
Type = {Article},
Language = {English},
DOI = {10.1016/j.cej.2025.166403},
EarlyAccessDate = {JUL 2025},
