@article{ WOS:001618664800001,
Author = {Zhao, Zhi-Yan and Cao, Wei and Hu, Zhi-Yong and Xu, Rui-Jie and Zhang,
   Xin and Jin, Chun-Qi and Chen, Qi-Dai and Liu, Xue-Qing},
Title = {Tunable Thermal Emitters Based on Femtosecond Laser Structured SiC for
   High Power Chip Heat Dissipation},
Journal = {NANO LETTERS},
Year = {2025},
Volume = {25},
Number = {48},
Pages = {16877-16884},
Month = {DEC 3},
Abstract = {Efficient thermal management based on wide-bandgap semiconductor
   materials plays a crucial role in enhancing the performance of high
   power devices aimed at next-generation information technology. Silicon
   carbide (SiC), a representative wide-bandgap semiconductor, requires
   controllable spectral modulation for efficient thermal management.
   However, the intrinsic reststrahlen band of SiC restricts its thermal
   emission in the atmospheric window. Here, tunable thermal emitters are
   fabricated on SiC by femtosecond laser hybrid technology, achieving a
   high emissivity of 97.4\% in the range of 2.5-16 mu m. As a proof of
   concept, the thermal emitter can be introduced on the chip for heat
   dissipation with a decrease of 6.6 degrees C. This work provides a new
   perspective on thermal radiation regulation of wide-bandgap
   semiconductor materials and demonstrates potential applications in chip
   heat dissipation.},
Type = {Article},
Language = {English},
