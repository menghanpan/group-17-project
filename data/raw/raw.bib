@article{ WOS:000615689300007,
Author = {Mazumder, Baishakhi and Sarker, Jith},
Title = {Probing structural and chemical evolution in (AlxGa1-x)2O3 using atom
   probe tomography: A review},
Journal = {JOURNAL OF MATERIALS RESEARCH},
Year = {2021},
Volume = {36},
Number = {1, SI},
Pages = {52-69},
Month = {JAN},
Abstract = {(AlxGa1-x)(2)O-3 is a novel ultra-wide bandgap semiconductor with the
   potential to dominate future power electronics industries.
   High-performance devices demand high Al content in (AlxGa1-x)(2)O-3 but
   are limited by crystallinity degradation resulting from phase
   separation. Additionally, the solubility limit of Al is still under
   debate, and conclusive research is in progress. (AlxGa1-x)(2)O-3 is also
   limited in high-frequency applications owing to low carrier mobility and
   requires n-type doping. For commercializing this material, the major
   obstacle is understanding dopant's behavior in the host
   (AlxGa1-x)(2)O-3. To investigate these issues, an advanced
   characterization technique, atom probe tomography (APT), was employed to
   analyze the structural-chemical evolution of (AlxGa1-x)(2)O-3. In this
   review, we summarized our recent works on the structure-chemistry
   investigation of (AlxGa1-x)(2)O-3 with alloy composition and doping
   interaction. We introduced machine learning algorithms on APT data to
   reveal unrivaled knowledge, previously not achievable with conventional
   methodologies. The outstanding capabilities of APT to study
   (AlxGa1-x)(2)O-3 with Al composition and doping will be considered
   significant for the wide bandgap semiconductors community.},
Type = {Review},
Language = {English},
DOI = {10.1557/s43578-020-00072-7},
EarlyAccessDate = {FEB 2021},
Keywords = {atom probe tomography; chemical composition; phase transformation;
   dopant},
Affiliations = {State University of New York (SUNY) System; University at Buffalo, SUNY},
