@article{ WOS:001536594700002,
Author = {Stanitska, Mariia and Obushak, Mykola and Grazulevicius, Juozas Vidas},
Title = {MODIFICATION BY FLUORINE AS EFFICIENT TOOL FOR THE ENHANCEMENT OF THE
   PERFORMANCE OF ORGANIC ELECTROACTIVE COMPOUNDS-A REVIEW},
Journal = {CHEMISTRY \& CHEMICAL TECHNOLOGY},
Year = {2025},
Volume = {19},
Number = {1},
Pages = {52-60},
Abstract = {Functionalization of organic semiconductors with fluorine atoms and
   fluorine-containing groups can give rise to a wide variety of
   properties, for example, increase the rate of electron transport, induce
   harvesting of non-emissive triplet excitons through thermally activated
   delayed fluorescence (TADF) or room temperature phosphorescence (RTP),
   improve photoluminescence quantum yield (PLQY) by forming multiple
   intra-and intermolecular interactions, and increase
   solutionprocessabitily of the compounds, therefore, lowering the cost of
   device fabrication. Diverse synthetic approaches have been implemented
   to afford fluorinated organic semiconductors. In this review, we discuss
   some of the recent and most interesting organic semiconductors with C-F
   and C-CF3 bonds as well as their application.},
