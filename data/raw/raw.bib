@article{ WOS:001371827900001,
Author = {Wei, Lai and Zhao, Yiming and Xing, Suli and Zhang, Jianwei and Yin,
   Changping and Wu, Nan},
Title = {Regulation of electromagnetic wave absorption properties for Co3Fe7
   through wide bandgap semiconductor coating},
Journal = {JOURNAL OF ALLOYS AND COMPOUNDS},
Year = {2025},
Volume = {1010},
Month = {JAN 5},
Abstract = {FeCo-based alloy particles are considered optimal materials for
   electromagnetic wave absorption due to superior magnetic properties,
   diverse loss mechanisms, and high curie temperatures. However, the
   impedance mismatch and the narrow effective absorption bandwidth (EAB)
   constrain further optimization in the field of wave absorption. In this
   study, wide bandgap semiconductor materials were coated on flake-like
   Co3Fe7 absorbents using the ball milling method. The microstructure and
   composition of the absorbents were subjected to analysis. The results
   showed that the coating structure of the composite absorbents was
   successfully constructed. The reduction of extensive conductive
   networks, coupled with the presence of numerous heterogeneous
   interfaces, can improve impedance matching performance and amplify
   polarization effects. The minimum reflection loss (RLmin) of composite
   absorbents is 2.03 times higher than that of pure Co3Fe7, and the EAB
   can increase by a factor of 2.93. The Co3Fe7/ZnO absorbents show an
   excellent RLmin value of -60.5 dB with a thickness of 1.5 mm, and the
   EAB is 6.3 GHz from 11.7 to 18.0 GHz. This study offers an additional
   foundation for future research concerning the design and application of
   magnetic alloy absorbents.},
Type = {Article},
Language = {English},
DOI = {10.1016/j.jallcom.2024.177792},
EarlyAccessDate = {NOV 2024},
