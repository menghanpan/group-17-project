@article{ WOS:000700877100054,
Author = {Zhang, Ziye and Qi, Ning and Wu, Yichu and Chen, Zhiquan},
Title = {Pressure-Induced Enhancement of Thermoelectric Performance in Rubrene},
Journal = {ACS APPLIED MATERIALS \& INTERFACES},
Year = {2021},
Volume = {13},
Number = {37},
Pages = {44409-44417},
Month = {SEP 22},
Abstract = {In this work, the thermoelectric performance of a typical small-molecule
   organic semiconductor rubrene under different hydrostatic pressures was
   studied by first-principles calculation and molecular dynamics
   simulation. The ZT value of rubrene can reach 1.6 at 400 K due to an
   unprecedented increase in hole mobility under hydrostatic pressure. The
   underlying mechanism is ascribed to the suppression of low-frequency
   phonons (which weakens electron-phonon scattering) and the increase in
   the intermolecular electronic coupling. The effect of uniaxial stress
   has also been investigated to confirm this conclusion. Our results
   provide meaningful insights to understand the relationship between
   thermoelectric properties and hydrostatic pressure in organic
   semiconductors.},
Type = {Article},
Language = {English},
DOI = {10.1021/acsami.1c12832},
EarlyAccessDate = {SEP 2021},
Keywords = {thermoelectric; rubrene; pressure; first-principles; molecular dynamics},
Keywords-Plus = {NONEQUILIBRIUM MOLECULAR-DYNAMICS; FIELD-EFFECT TRANSISTORS; ORGANIC
   SEMICONDUCTORS; HIGH-MOBILITY; CHARGE-TRANSPORT; SINGLE-CRYSTALS;
   PREDICTION},
