@article{ WOS:001575286000004,
Author = {Shi, Jiawang and Chen, Yiren and Zhang, Jiayu and Li, Wenhui and Lv,
   Weichao and Sun, Xiaojuan and Miao, Guoqing and Li, Dabing},
Title = {Advanced monolithic integration strategies on wide-bandgap
   semiconductors: the two-dimensional material heterogeneous integration
   and the system-level multi-functional integration},
Journal = {MATERIALS TODAY CHEMISTRY},
Year = {2025},
Volume = {49},
Month = {OCT},
Abstract = {In the post-Moore era, as traditional silicon-based semiconductor
   processes approach physical limits, the integrated circuit industry is
   transitioning from ``process scaling{''} to ``system-level
   innovation.{''} Technical pathways based on wide-bandgap semiconductor
   (WBGS) integration strategies, which encompass heterogeneous integration
   and multi-functional integration, have emerged as two core directions
   for overcoming performance bottlenecks in optoelectronic devices.
   Leveraging their high breakdown electric fields, superior thermal
   conductivity, and excellent high-frequency characteristics, WBGSs
   provide foundational support for efficient energy conversion and
   high-speed signal processing. Concurrently, two-dimensional (2D)
   material heterogeneous integration technology enables material
   diversification, transcending the limitations of single-process
   platforms to achieve synergistic improvements in system-level energy
   efficiency and power density. In addition, systemlevel multi-functional
   integration drives electronic systems toward
   ``sensing-computing-storage-communication{''} architectures, thereby
   reducing system latency and power consumption. Looking ahead, the
   scalable application of WBGS in heterogeneous integration and
   system-level multi-functional integration will present both critical
   challenges and opportunities for sustained innovation. This review
   summarizes recent advances in WBGS-based heterogeneous integration and
   multi-functional integration strategies, exploring their applications in
   power electronics, optoelectronics, and photonic integration, thereby
   offering a comprehensive perspective on technological breakthroughs in
   the optoelectronic domain during the post-Moore era.},
