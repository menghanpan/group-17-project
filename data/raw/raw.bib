@article{ WOS:001378774100001,
Author = {Chen, Liangliang and Wang, Ying and Liu, Zitong},
Title = {Diphenylperylene Isomers as Novel Emissive Organic Semiconductors},
Journal = {ASIAN JOURNAL OF ORGANIC CHEMISTRY},
Year = {2025},
Volume = {14},
Number = {2},
Month = {FEB},
Abstract = {Emissive organic semiconductors are crucial for integrated
   optoelectronic devices, yet only a limited number of materials exhibit
   high mobility and high photoluminescence quantum yield because of the
   contradictory requirements for molecular stacking. In this study, two
   diphenylperylene isomers, 39P-Ph and 310P-Ph, were successfully
   synthesized through a one-step process by varying the positions of the
   substituent phenyl groups on the perylene core. Both compounds were
   comprehensively characterized and demonstrated excellent hole transport
   capabilities and moderate photoluminescence quantum yield (PLQY), along
   with long-wavelength emission, establishing them as effective emissive
   organic semiconductors. 39P-Ph emits orange-yellow fluorescence in
   crystalline powder with an absolute PLQY of 15.4 \% and 310P-Ph shows
   orange-red emission with an emissive wavelength of up to 612 nm in 17.5
   \% PLQY. Moreover, the carrier mobilities of 39P-Ph and 310P-Ph are up
   to 3.05 cm2 V-1 s-1 and 1.36 cm2 V-1 s-1, respectively, based on the
   single-crystal devices. These results reveal that 39P-Ph and 310P-Ph are
   promising candidates as emissive semiconductors, offering a balance
   between efficient charge transport and light emission for integrated
   optoelectronic applications.},
Type = {Article},
Language = {English},
DOI = {10.1002/ajoc.202400608},
