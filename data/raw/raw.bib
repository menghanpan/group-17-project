@article{ WOS:001600414500001,
Author = {Wang, Hui and Yousaf, Shamaila and Firdous, Khadeeja and Aslam, Adnan},
Title = {QSPR modeling of organic semiconductor building blocks using topological
   indices},
Journal = {ZEITSCHRIFT FUR NATURFORSCHUNG SECTION A-A JOURNAL OF PHYSICAL SCIENCES},
Year = {2025},
Volume = {80},
Number = {12},
Pages = {1171-1184},
Month = {DEC 17},
Abstract = {Topological indices are numerical descriptors that capture key
   structural information of molecular graphs, enabling the quantitative
   prediction of chemical properties. This study employs five degree-based
   topological indices to develop quantitative structure property
   relationship (QSPR) models for twenty fundamental building blocks of
   organic semiconductors. Strong correlations are established between
   these indices and critical physicochemical properties including melting
   point, boiling point, and molecular mass using linear, quadratic, and
   logarithmic regression approaches. Molecular mass and boiling point are
   found to be particularly well predicted, with correlation coefficients
   exceeding 0.99 in multiple models. The results are validated against
   experimental data, confirming the practical utility of the proposed
   models. These findings underscore the value of topological indices as
   efficient computational tools for the high-throughput screening and
   rational design of organic semiconductor materials.},
Type = {Article},
Language = {English},
DOI = {10.1515/zna-2025-0287},
