@inproceedings{ WOS:001665554100198,
Author = {Bi, Lantian and Zhang, Hong and Han, Ying and Yuan, Tianshu and Ma,
   Dingkun and Xia, Hongyan and Wang, Laili},
Book-Group-Author = {IEEE},
Title = {Optimization of Electric Field Distribution in Wide-Bandgap
   Semiconductor Power Modules via cBN-PI Composite Coating},
Booktitle = {2025 IEEE ENERGY CONVERSION CONFERENCE CONGRESS AND EXPOSITION, ECCE},
Series = {IEEE Energy Conversion Congress and Exposition},
Year = {2025},
Note = {2025 Energy Conversion Congress and Exposition-ECCE-Annual,
   Philadelphia, PA, OCT 19-23, 2025},
Abstract = {High-voltage power modules are critically challenged by electric field
   concentration at triple points, which accelerates partial discharge,
   severely limiting operational reliability. To address this issue, a
   novel insulating material with dual-enhanced high permittivity and
   exceptional dielectric strength was engineered by integrating boron
   nitride (BN) fillers into a polyimide (PI) matrix. When coated at triple
   points, this composite effectively redistributes interfacial electric
   fields, reducing the maximum field intensity in silicone gel by 72.85\%
   compared to uncoated substrates, as validated by finite element analysis
   (FEA) simulation and experimental partial discharge (PD) test. The
   coating elevates the partial discharge inception voltage to over 10 kV
   under DC power supply. This advancement enhances the voltage endurance
   and longevity of wide-bandgap semiconductor modules, enabling reliable
   deployment in highvoltage applications such as electric vehicles and
   renewable energy systems.},
Type = {Proceedings Paper},
Language = {English},
DOI = {10.1109/ECCE58356.2025.11259701},
