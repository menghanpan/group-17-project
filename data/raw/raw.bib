@article{ WOS:001575156900002,
Author = {Song, Ruonan and Yao, Zehui and Jiang, Yining and Bi, Sheng and Piao,
   Junxiu and Zhang, Zitian and Han, Xu and Yang, Xiaoran and Bi, Congjie
   and Asare-Yeboah, Kyeiwaa and He, Zhengran},
Title = {Study of comparative effects of semicrystalline and amorphous polymer
   additives on crystallinity, stability and electrical hysteresis of
   high-mobility organic semiconductors},
Journal = {ORGANIC ELECTRONICS},
Year = {2025},
Volume = {146},
Month = {NOV},
Abstract = {Enhancing the electrical performance of small-molecule organic
   semiconductors by blending them with polymer additives has become a
   common approach to achieving high-quality crystalline films. Despite its
   widespread use, limited research exists on how semicrystalline versus
   amorphous polymer additives of identical molecular weight impact the
   behavior of organic semiconductors, especially with respect to
   electrical hysteresis and stability in air-two key considerations for
   scaling up organic thin-film transistors (OTFTs) for industrial
   applications. This study bridges this knowledge gap by examining the
   influence of semicrystalline poly (ethylene oxide) (PEO) and amorphous
   poly (alpha-methylstyrene) (P alpha MS) on the crystallinity,
   morphology, hysteresis, and air stability of 6,13bis(triisopropylsilyl)
   pentacene (TIPS pentacene). While X-ray diffraction (XRD) and optical
   microscopy revealed that PEO enhanced crystallinity, its hydroxyl groups
   caused charge trapping, leading to greater hysteresis and diminished
   stability in air. Conversely, P alpha MS not only improved charge
   mobility but also minimized hysteresis and enhanced stability by
   providing hydrophobic encapsulation. Scanning electron microscopy (SEM)
   further demonstrated a distinct vertical phase segregation in TIPS
   pentacene/P alpha MS blends, which contributed to their improved
   performance. By incorporating 50 \% P alpha MS, the hole mobility of
   TIPS pentacene rose 18-fold to 1.08 cm2/Vs, marking the highest mobility
   achieved for drop-cast TIPS pentacene/P alpha MS films without advanced
   alignment techniques or surfactants. This research offers the first
   side-by-side comparison of semicrystalline and amorphous polymers with
   the same molecular weight, providing critical insights into how polymer
   type affects organic semiconductor properties and advancing the
   development of high-performance organic electronic devices.},
Type = {Article},
Language = {English},
DOI = {10.1016/j.orgel.2025.107315},
EarlyAccessDate = {AUG 2025},
Article-Number = {107315},
Keywords = {Small molecule organic semiconductor; Hole mobility; Electrical
   hysteresis; Air stability},
Keywords-Plus = {PERFORMANCE; MORPHOLOGY; TRANSISTORS; BEHAVIOR},
Affiliations = {Dalian University of Technology; Dalian University of Technology; Key
