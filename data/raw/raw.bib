@article{ WOS:001642251300001,
Author = {Tan, Yifei and Zhang, Ziyi and Xu, Ning and Wang, Xiaohong and Ni, Fan
   and Qiu, Longzhen},
Title = {Robust Photo-Cross-Linked Polymer Semiconductors for Fully Stretchable
   and Photopatternable Electronics},
Journal = {CHEMISTRY OF MATERIALS},
Year = {2026},
Volume = {38},
Number = {1},
Pages = {138-148},
Month = {JAN 13},
Abstract = {Organic semiconductors are widely employed in flexible electronic
   devices due to their excellent solution processability. However,
   improving their mechanical properties often comes at the cost of
   diminished electrical performance. Here, we present a photochemical
   cross-linking strategy that simultaneously achieves high ductility and
   high charge carrier mobility. A benzophenone-capped polydimethylsiloxane
   (BP-PDMS) elastomer was synthesized as a photo-cross-linking agent and
   blended with a semicrystalline diketopyrrolopyrrole (DPP)-based polymer
   bearing siloxane side chains. Films with varying BP-PDMS content were
   cured under UV irradiation (365 nm, 30 mW cm-2), yielding mechanically
   robust, low-modulus networks. At polymer -to- cross-linker ratios of
   10:1, 10:2, and 10:3, the films exhibited crack-free stretchability up
   to 100\% strain. Notably, the charge carrier mobility parallel to the
   stretching direction exceeded 0.5 cm2 V-1 s-1 in the 10:2 and 10:3
   films, surpassing that of the unstretched state due to strain-induced
   chain alignment. Fully stretchable transistor devices based on these
   cross-linked films demonstrated stable electrical performance under
   tensile deformation. Furthermore, the photo-cross-linked networks
   exhibited similar to 80\% retention of charge carrier mobility after 10
   min solvent immersion and enabled precise photopatterning with minimum
   feature sizes of 13.6 mu m. This work introduces an effective and
   scalable approach for designing organic semiconductors with combined
   mechanical resilience and high electronic performance, advancing the
   development of next-generation deformable electronic devices.},
Type = {Article},
Language = {English},
DOI = {10.1021/acs.chemmater.5c02018},
EarlyAccessDate = {DEC 2025},
Affiliations = {Hefei University of Technology},
Cited-References = {Bruin MAC, 2021, BASIC CLIN PHARMACOL, V128, DOI 10.1111/bcpt.13523.
   Cao XX, 2024, AGGREGATE, V5, DOI 10.1002/agt2.501.
   Chang TW, 2023, ACS APPL MATER INTER, V15, P51507, DOI 10.1021/acsami.3c10033.
   Cheng HW, 2022, ACS MATER LETT, V4, P2328, DOI 10.1021/acsmaterialslett.2c00749.
