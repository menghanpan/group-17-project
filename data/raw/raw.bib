@article{ WOS:000682527600008,
Author = {Gao, Wei and Yu, Siu Fung},
Title = {Reality or fantasy-Perovskite semiconductor laser diodes},
Journal = {ECOMAT},
Year = {2021},
Volume = {3},
Number = {1},
Month = {FEB},
Abstract = {Perovskite semiconductor has emerged as a promising laser gain medium;
   however, it is still a challenge to fabricate electrically pumped
   perovskite lasers due to the insufficient electrical-to-optical
   conversion efficiency. Here, the current progress on the lasing
   performance of optically pumped perovskite lasers is reviewed. The
   advancement in the control of carrier transport and recombination
   properties of perovskite light-emitting diode architectures is also
   studied. Hence, the obstacles preventing the fabrication of perovskite
   laser diodes are investigated. More importantly, a strategy toward
   electrically driven perovskite lasers is proposed base on the successful
   development of organic semiconductor laser diodes.},
