@article{ WOS:000971727500002,
Author = {Hao, Jiandong and Li, Ling and Gao, Peng and Jiang, Xiangqian and Ban,
   Chuncheng and Shi, Ningqiang},
Title = {Deep ultraviolet detectors based on wide bandgap semiconductors: a
   review},
Journal = {JOURNAL OF NANOPARTICLE RESEARCH},
Year = {2023},
Volume = {25},
Number = {4},
Month = {APR},
Abstract = {Deep ultraviolet (DUV) light is easily absorbed by the ozone layer.
   There is no interference from DUV light at ground and low altitude.
   Therefore, DUV detection has high applications in criminal
   investigation, the security monitoring of power grid, and forest fire
   alarm. Wide bandgap semiconductors are more suitable for nanodevices
   with high frequency and high reaction rate, which have wide bandgap,
   high electron saturation mobility, high thermal conductivity, and high
   breakdown strength. In this paper, the nanostructures, self-powered
   technologies, flexible substrates, electrical characteristics, and
   simulation optimization of wide bandgap semiconductors are thoroughly
   summarized with recent studies. The working principle, application,
   optimization, and technical difficulties of DUV detectors are also
   discussed.},
Type = {Review},
Language = {English},
