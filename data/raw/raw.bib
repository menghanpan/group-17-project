@article{ WOS:000644918400001,
Author = {Zou, Xiangyu and Cui, Shuaiwei and Li, Junqiang and Wei, Xueling and
   Zheng, Meng},
Title = {Diketopyrrolopyrrole Based Organic Semiconductor Materials for
   Field-Effect Transistors},
Journal = {FRONTIERS IN CHEMISTRY},
Year = {2021},
Volume = {9},
Month = {APR 14},
Abstract = {Over the past several decades, organic conjugated materials as
   semiconductors in organic field effect transistors (OFETs) have
   attracted more and more attention from the scientific community due to
   their intriguing properties of mechanical flexibility and solution
   processability. However, the device fabrication technique, design, and
   synthesis of novel organic semiconductor materials with high charge
   carrier mobility is crucial for the development of high-performance
   OFETs. In the past few years, more and more novel materials were
   designed and tested in the OFETs. Among which, diketopyrrolopyrrole
   (DPP) and its derivatives, as the electron acceptors to build
   donor-acceptor (D-A) typed materials, are the perspective. In this
   article, recently reported molecules regarding the DPP and its
   derivatives for OFETs application are reviewed. In addition, the
   relationship between the chemical structures and the performance of the
   device are discussed. Furthermore, an outlook of DPP-based materials in
   OFETs with a future design concept and the development trend are
   provided.},
