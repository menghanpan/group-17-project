@article{ WOS:001638304100001,
Author = {Song, Yu and Dong, Sheng and Cao, Yunhao and Wang, Yazhong and Yang,
   Xiye and Jia, Tao and Shao, Lin and Lan, Linfeng and Yu, Gang and Huang,
   Fei},
Title = {High-Performance Short-Wave-Infrared Imager Based on the PbS Quantum
   Dot/Organic BHJ Hybrid Structure},
Journal = {IEEE TRANSACTIONS ON ELECTRON DEVICES},
Year = {2026},
Volume = {73},
Number = {1},
Pages = {440-448},
Month = {JAN},
Abstract = {Short-wave-infrared (SWIR) photodetectors (PDs) have attracted great
   interest for advanced active imaging applications. Compared with
   epitaxially grown inorganic semiconductors, quantum dots (QDs) and
   organic semiconductors have been regarded as promising candidates for
   infrared sensing due to the solution processibility and monolithic
   integrated ability with silicon-based readout circuits. However, owing
   to high dark currents, achieving sensitive photodetection remains a big
   challenge for solution-processed SWIR PDs. Herein, we report a
   high-performance photodiode with the PbS QD/organic bulk-heterojunction
   (BHJ) hybrid structure, which exhibited a low dark current density of
   1.89 x 10(-7) A<middle dot>cm(-2) and a high specific detectivity of 2.0
   x 10(12) Jones at 1520 nm at room temperature. By integrating with a
   CMOS readout circuit (640 x 512 pixels), a high-performance SWIR imager
   has been successfully fabricated with a solution-processed approach.
   Systematic analyses suggest the PbS QD/organic BHJ hybrid structure not
   only suppressed the trap-assisted recombination, but also improved the
   charge transport and extraction, as well as enhanced the
   photosensitivity and response speed.},
Type = {Article},
Language = {English},
DOI = {10.1109/TED.2025.3636484},
