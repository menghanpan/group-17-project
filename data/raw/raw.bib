   Maeshima, Hiroyuki and Kaneko, Hiromasa},
Title = {Exploring Molecular Descriptors and Acquisition Functions in Bayesian
   Optimization for Designing Molecules with Low Hole Reorganization Energy},
Journal = {ACS OMEGA},
