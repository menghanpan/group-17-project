Title = {Directly Patterning Conductive Polymer Electrodes on Organic
   Semiconductor via In Situ Polymerization in Microchannels for
   High-Performance Organic Transistors},
Journal = {ACS APPLIED MATERIALS \& INTERFACES},
Year = {2021},
