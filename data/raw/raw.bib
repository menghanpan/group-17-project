@article{ WOS:001382734600001,
Author = {Wei, Huan and Guo, Jing and Liu, Heng and Wu, Tong and Chen, Ping-An and
   Dong, Chuanding and Wang, Shu-Jen and Schumacher, Stefan and Bai, Yugang
   and Lei, Ting and Wang, Suhao and Hu, Yuanyuan},
Title = {Novel Phosphazenium Tetrafluoroborate Dopant Enables Efficient and
   Thermally Stable n-Doped Organic Semiconductors},
Journal = {ADVANCED ELECTRONIC MATERIALS},
Year = {2026},
Volume = {12},
Number = {6, SI},
Month = {MAR},
Abstract = {Thermal stability is crucial for doped organic semiconductors (OSCs) and
   their applications in organic thermoelectric (OTE) devices. However, the
   capacity of n-dopants to produce thermally stable n-doped OSC films has
   not been thoroughly explored, with few reports of high thermal
   stability. Here, a novel n-dopant, phosphazenium tetrafluoroborate
   (P2BF4) is introduced, which effectively induces n-doping in N2200,
   P(PzDPP-CT2) and several other commonly used OSCs. Remarkably, the
   electrical conductivity of P2BF4-doped OSC films remains almost
   unchanged even after heating at temperatures > 150 degrees C for 24 h,
   far superior to the films doped with benchmark N-DMBI. The exceptional
   thermal stability observed in P2BF4-doped P(PzDPP-CT2) films allows for
   stable operation of the corresponding organic thermoelectric devices at
   150 degrees C for 16 h, a milestone not previously achieved. This study
   offers valuable insights into the development of n-dopants capable of
   producing OSCs with outstanding thermal stability, paving the way for
   the practical realization of OTE devices with enhanced operation
   stability.},
Type = {Article},
Language = {English},
DOI = {10.1002/aelm.202400767},
EarlyAccessDate = {DEC 2024},
