@article{ WOS:001458405900001,
Author = {Li, Xiaoxiao and Wu, Yue and Yang, Hang and Fan, Hongyu and Hu, Kewei
   and Cui, Chaohua and Li, Yongfang},
Title = {Molecular Stacking Regulation of Organic Semiconductors Via
   Intermolecular Interaction Enables High-Performance Organic Solar Cells},
Journal = {ADVANCED FUNCTIONAL MATERIALS},
Year = {2025},
Volume = {35},
Number = {36},
Month = {SEP},
Abstract = {The ordered pi-stacking with face-on orientation and uniform phase
   separation in active layer is essential to develop high-performance
   organic solar cells (OSCs). Differing from phase separation
   optimization, it is challenging to regulate the molecular stacking of
   organic semiconductors during the film-formation process. In this
   contribution, a universal strategy is established to simultaneously
   optimize the pi-stacking and aggregation of organic semiconductors via
   intermolecular interaction with solid additive. It is demonstrated that
   the strong intermolecular interaction between solid additive and organic
   semiconductors is a critical factor in molecular stacking regulation.
   Benefitting from the more ordered molecular stacking of active layer
   aroused by the additive treatment, significantly improved photovoltaic
   performance can be realized in OSCs. Particularly, an outstanding
   power-conversion efficiency (PCE) of 20.04\% is achieved in the
   D18:N3:AQx-2F-based device treated by thioxanthene, while the control
   device without additive treatment yields a much lower PCE of 19.00\%.},
Type = {Article},
Language = {English},
DOI = {10.1002/adfm.202503986},
EarlyAccessDate = {APR 2025},
Article-Number = {2503986},
Keywords = {intermolecular interaction; molecular stacking; organic solar cells;
   power-conversion efficiency; solid additive},
Keywords-Plus = {EFFICIENCY},
Affiliations = {Soochow University - China; Soochow University - China; Chinese Academy
   of Sciences; Institute of Chemistry, CAS},
Cited-References = {Bao SN, 2021, ADV MATER, V33, DOI 10.1002/adma.202105301.
   Beaujuge PM, 2011, J AM CHEM SOC, V133, P20009, DOI 10.1021/ja2073643.
   Burgués-Ceballos I, 2021, JOULE, V5, P2261, DOI 10.1016/j.joule.2021.07.004.
