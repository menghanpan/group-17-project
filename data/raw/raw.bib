@article{ WOS:001436043400001,
Author = {Wang, Qiao and Wan, Chengliang and Wu, You and Fan, Xuhong and Wang,
   Shuai and Pan, Yuzhou and Khalid, Mansoor and Xiao, Haiying and Zhang,
   Hongqiang and Ma, Guoliang and Fu, Yongqing and Hu, Ping-An},
Title = {Plastic Inorganic van der Waals Semiconductors for Flexible X-ray
   Detectors},
Journal = {ACS APPLIED ELECTRONIC MATERIALS},
Year = {2025},
Volume = {7},
Number = {5},
Pages = {1764-1774},
Month = {MAR 3},
Abstract = {Radiation detectors that are low-cost, portable, and operating at
   ambient temperature are highly desirable, especially if they are
   combined with flexibility and miniaturization. Plastic inorganic
   semiconductors, distinguished by their excellent electrical and
   mechanical properties, are promising candidates for portable and
   wearable radiation detectors. Herein, we demonstrate the potential of
   plastic inorganic van der Waals single crystals as flexible solid-state
   radiation detectors operating at room temperature. This study discovers
   that van der Waals materials such as gallium telluride (GaTe) show high
   plasticity as well as remarkable radiation detection characteristics,
   including high absorption coefficient and large mobility-lifetime (mu
   tau) product (similar to 2 x 10-3 cm2 V-1), which make them high-quality
   materials for constructing flexible X-ray detectors. The GaTe-based
   X-ray detector with asymmetric metal electrodes achieved an extremely
   low electric field of 1 x 10-4 V mu m-1, and the detection sensitivity
   is as high as 40980 mu C Gyair -1 cm-2. The device performance was
   unaffected by its bending status, showing superior stability during
   prolonged exposure to continuous gamma-ray radiation (total dose: 5000
   Gy). Our research should be easily generalizable to other van der Waals
   semiconductors for fabricating flexible radiation sensors that can be
   embedded in curved or deformable systems.},
Type = {Article},
Language = {English},
DOI = {10.1021/acsaelm.4c01931},
EarlyAccessDate = {MAR 2025},
Keywords = {plastic inorganic semiconductors; van der Waals materials; X-ray
   detectors; flexible devices; ductilematerials; wearable detectors;
   gallium telluride},
